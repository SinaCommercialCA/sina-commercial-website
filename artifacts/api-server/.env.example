# Sina Commercial — API Server Environment Variables
# Copy to .env and replace placeholders with real values.
# NEVER commit .env to version control.

# ── Pipedrive ─────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=your_pipedrive_api_token_here
PIPEDRIVE_BASE_URL=https://sinacommercial.pipedrive.com/api/v1

# ── Google Sheets ─────────────────────────────────────────
# Paste the full service account JSON as a single line, or provide a file path.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Telegram Notifications ────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_PER_IP=10
RATE_LIMIT_WINDOW_SEC=3600

# ── General ───────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
